# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-chars

# PostgreSQL (required) – replace YOUR_PASSWORD with your Postgres password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/employee_management

# Default admin (used by seed.py and reset_admin.py)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=admin123
